{
    "name": "@fozy-labs/astp",
    "version": "0.1.5",
    "type": "module",
    "private": false,
    "description": "A command-line tool for generating skills, instrustions and other files for you AI workflow.",
    "homepage": "https://github.com/fozy-labs/astp#readme",
    "bugs": {
        "url": "https://github.com/fozy-labs/astp/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fozy-labs/astp.git"
    },
    "license": "GPL-3.0-or-later",
    "author": "Vladimir Panev <vova6255@gmail.com>",
    "bin": {
        "astp": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "rimraf ./dist && tsc && tsc-alias",
        "build:watch": "npm run build && (concurrently \"tsc -w\" \"tsc-alias -w\")",
        "ts-check": "tsc --noEmit",
        "test": "tsc -p tsconfig.test.json && vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "dependencies": {
        "@clack/prompts": "^1.1.0",
        "commander": "^14.0.0",
        "giget": "^2.0.0"
    },
    "devDependencies": {
        "@fozy-labs/js-configs": "^0.1.3",
        "@types/node": "^22.0.0",
        "concurrently": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "rimraf": "^6.0.0",
        "tsc-alias": "^1.8.0",
        "typescript": "^5.0.0",
        "vitest": "^4.0.0"
    },
    "prettier": "@fozy-labs/js-configs/prettier"
}
